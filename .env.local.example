OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DATABASE_PATH=./data/familybrain.sqlite
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=familybrain_chunks
FAMILYBRAIN_USERNAME=admin
FAMILYBRAIN_PASSWORD=change-this-development-password
FAMILYBRAIN_SESSION_SECRET=change-this-to-at-least-32-random-characters

# Optional: OpenAI key/model can also be set in the UI (Einstellungen).
# UI settings in SQLite take precedence over these env vars.

# Docker: copy `.env.example` → `.env` and see README “Docker”.
