# Optional – OpenAI can also be set in the UI (Einstellungen).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Host port mapping (container always listens on 3000)
FAMILYBRAIN_PORT=3000

# Paperless base URL + API token: configure in the UI after first start.
# You can use the same external Paperless URL you already use in the browser.
