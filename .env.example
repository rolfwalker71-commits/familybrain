# Optional – OpenAI can also be set in the UI (Einstellungen).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=familybrain_chunks
# Host ports for Qdrant REST/UI (6333) and gRPC (6334). Keep local/VPN only — no auth.
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Host port mapping (container always listens on 3000 internally)
FAMILYBRAIN_PORT=3100

# Pre-built image tag from GHCR (default: latest from main)
FAMILYBRAIN_IMAGE_TAG=latest

# Required login for desktop browser and installed PWA.
FAMILYBRAIN_USERNAME=admin
# Recommended: run `npm run auth:secrets -- 'your secure password'` and copy
# the generated hash + session secret here. Leave FAMILYBRAIN_PASSWORD empty.
FAMILYBRAIN_PASSWORD=
FAMILYBRAIN_PASSWORD_HASH=
FAMILYBRAIN_SESSION_SECRET=

# Paperless base URL + API token: configure in the UI after first start.
# You can use the same external Paperless URL you already use in the browser.
